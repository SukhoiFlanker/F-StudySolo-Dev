# ============================================
# StudySolo Backend - Environment Variables Template
# ============================================
# Copy this file to .env and fill in real values
# cp .env.example .env
# ============================================

# Server
PORT=2038
ENVIRONMENT=development

# Supabase Access Token (for MCP/CLI tools)
# https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=sbp_xxx

# Supabase Project Config
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJxxx

# GitHub Personal Access Token
GITHUB_PERSONAL_ACCESS_TOKEN=github_pat_xxx

# ============================================
# AI Platform API Keys & Base URLs
# ============================================

# 火山引擎 (Volcengine)
VOLCENGINE_API_KEY=xxx
VOLCENGINE_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# 阿里云百炼 (DashScope)
DASHSCOPE_API_KEY=xxx
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# DeepSeek
DEEPSEEK_API_KEY=xxx
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# 月之暗面 (Moonshot)
MOONSHOT_API_KEY=xxx
MOONSHOT_BASE_URL=https://api.moonshot.cn/v1

# 智谱AI (Zhipu)
ZHIPU_API_KEY=xxx
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# 七牛云 (Qiniu)
QINIU_API_KEY=xxx
QINIU_BASE_URL=xxx

# 优云智算 (YouYun)
YOUYUN_API_KEY=xxx
YOUYUN_BASE_URL=xxx

# 硅基流动 (SiliconFlow)
SILICONFLOW_API_KEY=xxx
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1

# ============================================
# Security
# ============================================
JWT_SECRET=change-this-to-a-secure-random-string
CAPTCHA_SECRET=这里放一串强随机字符串
CORS_ORIGIN=http://localhost:2037

# ============================================
# Email Service (Aliyun DirectMail)
# 发件地址：accounts@email.1037solo.com（与 Platform 共用）
# ============================================
SMTP_HOST=smtpdm.aliyun.com
SMTP_PORT=80
SMTP_USER=xxx
SMTP_PASS=xxx
