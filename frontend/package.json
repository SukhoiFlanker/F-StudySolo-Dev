{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack -p 2037",
    "build": "next build",
    "start": "next start -p 2037",
    "lint": "eslint",
    "lint:lines": "pnpm lint:lines:strict && pnpm lint:pages",
    "lint:lines:strict": "node scripts/check-max-lines.mjs --mode strict",
    "lint:lines:ratchet": "node scripts/check-max-lines.mjs --mode ratchet --baseline scripts/max-lines-baseline.json && pnpm lint:pages",
    "lint:lines:baseline": "node scripts/check-max-lines.mjs --mode ratchet --baseline scripts/max-lines-baseline.json --write-baseline",
    "lint:pages": "node scripts/check-page-lines.mjs --max-lines 220 --exceptions scripts/page-lines-exceptions.json",
    "test": "vitest --run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.98.0",
    "@xyflow/react": "^12.10.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "katex": "^0.16.33",
    "localforage": "^1.10.0",
    "lucide-react": "^0.575.0",
    "next": "16.1.6",
    "nextjs-toploader": "^3.9.17",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-markdown": "^10.1.0",
    "recharts": "^2.15.0",
    "rehype-katex": "^7.0.1",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "shiki": "^3.23.0",
    "sonner": "^2.0.7",
    "streamdown": "^2.3.0",
    "tailwind-merge": "^3.5.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "fast-check": "^4.5.3",
    "shadcn": "^3.8.5",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "vitest": "^4.0.18"
  }
}
